# Provider chuno: groq (FREE) | openai | anthropic
RAG_PROVIDER=groq

# Groq (FREE) — console.groq.com se key lo
GROQ_API_KEY=gsk_...

# OpenAI (Paid)
OPENAI_API_KEY=sk-...

# Anthropic (Paid)
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# Model overrides (optional)
# RAG_LLM_MODEL=llama-3.3-70b-versatile
RAG_STORE_PATH=vector_store.json
